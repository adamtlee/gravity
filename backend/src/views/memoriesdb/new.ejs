<%- layout('layouts/main') %>
<h2>New Memory</h2>
<form action="/memories" method="POST">
    <label for="experience">Experience:</label>
    <input type="text" name="experience" id="experience" required>
    <label for="reflection">Reflection:</label>
    <input type="text" name="reflection" id="reflection" required>
    <button type="submit">Create Memory</button>
</form>
