<!DOCTYPE html>
<html>
<head>
  <title>Edit Memory</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css">
</head>
<body>
  <div class="container mt-4">
    <h1>Edit Memory</h1>
    <form action="/memories/edit/<%= memory.id %>" method="POST">
      <div class="mb-3">
        <label for="memory" class="form-label">Memory:</label>
        <textarea id="memory" name="memory" class="form-control" required><%= memory.memory %></textarea>
      </div>
      <div class="mb-3">
        <label for="reflection" class="form-label">Reflection:</label>
        <textarea id="reflection" name="reflection" class="form-control" required><%= memory.reflection %></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Update Memory</button>
    </form>
  </div>
</body>
</html>
