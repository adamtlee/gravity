<!DOCTYPE html>
<html>
<head>
  <title>Connections</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css">
</head>
<body>
  <div class="container mt-4">
    <h1>Connections</h1>
    <ul class="list-group">
      <% connections.forEach(connection => { %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <%= connection.first_name %><br>
          <%= connection.last_name %><br>
          <%= connection.relationship %><br>
          <%= connection.description %><br>
          <div>
            <form action="/connections/edit/<%= connection.id %>" method="GET" class="d-inline">
              <button type="submit" class="btn btn-sm btn-warning me-2">Edit</button>
            </form>
            <form action="/connections/delete/<%= connection.id %>" method="POST" class="d-inline">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </div>
        </li>
      <% }); %>
    </ul>
    <a href="/connections/add" class="btn btn-primary mt-3">Add a Connection</a>
  </div>
</body>
</html>
