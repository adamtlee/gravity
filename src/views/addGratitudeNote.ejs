<!DOCTYPE html>
<html>
<head>
  <title>Add Gratitude Note</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css">
</head>
<body>
  <div class="container mt-4">
    <h1>Add Gratitude Note</h1>
    <form action="/add" method="POST">
      <div class="mb-3">
        <label for="note" class="form-label">Gratitude Note:</label>
        <textarea id="note" name="note" class="form-control" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Add Gratitude Note</button>
    </form>
  </div>
</body>
</html>
